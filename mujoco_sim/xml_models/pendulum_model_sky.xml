<mujoco>
    <compiler angle="radian" coordinate="local"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <!-- VISUAL -->
    <visual>
        <headlight diffuse="0.4 0.4 0.4" ambient="0.2 0.2 0.2"/>
        <rgba haze="0.8 0.9 1 1"/>
        <quality shadowsize="4096" offsamples="8"/>
    </visual>

    <!-- ASSETS -->
    <asset>
        <!-- cielo con gradiente -->
        <texture type="skybox" builtin="gradient"
                 rgb1="1 1 1"
                 rgb2="0.7 0.85 1"
                 width="512" height="512"/>

        <!-- material piso -->
        <material name="floor_mat"
                  rgba="0.9 0.9 0.9 1"
                  specular="0.2"
                  shininess="0.3"/>

        <!-- materiales robot -->
        <material name="arm_mat"
                  rgba="0.8 0.2 0.2 1"
                  specular="0.5"
                  shininess="0.4"/>

        <material name="pendulum_mat"
                  rgba="0.2 0.6 0.2 1"
                  specular="0.5"
                  shininess="0.4"/>
    </asset>

    <worldbody>

        <!-- luces -->
        <light pos="0 0 3" dir="0 0 -1" castshadow="true"/>
        <light pos="2 2 3" diffuse="0.6 0.6 0.6" castshadow="true"/>

        <!-- piso -->
        <geom type="plane"
              pos="0 0 -0.4"
              size="3 3 0.1"
              material="floor_mat"
              contype="0"
              conaffinity="0"/>

        <body name="base" pos="0 0 0">
            <geom type="sphere"
                  size="0.05"
                  rgba="0.2 0.3 0.3 1"
                  contype="0"
                  conaffinity="0"/>

            <body name="link1" pos="0 0 0">
                <joint name="joint1" type="hinge" axis="0 0 1"/>

                <geom type="capsule"
                      fromto="0 0 0 0.15 0 0"
                      size="0.01"
                      mass="0.045"
                      material="arm_mat"/>

                <body name="pendulum" pos="0.15 0 0">
                    <joint name="encoder_joint"
                           type="hinge"
                           axis="1 0 0"
                           damping="0.0005"/>

                    <geom type="capsule"
                          fromto="0 0 0 0 0 0.2"
                          size="0.01"
                          mass="0.032"
                          material="pendulum_mat"/>
                </body>

            </body>
        </body>
    </worldbody>

    <actuator>
        <motor name="dc_motor" joint="joint1" gear="1"/>
    </actuator>

    <sensor>
        <jointpos joint="encoder_joint"/>
    </sensor>

</mujoco>